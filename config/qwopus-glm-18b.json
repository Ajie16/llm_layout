{
  "_comment": "Qwopus-GLM-18B 推理配置 | RX9060 XT 16GB 优化",
  "_doc": "详见 CONFIG_GUIDE.md",

  "model": {
    "path": ".\\models\\Qwopus-GLM-18B-Healed-Q4_K_M.gguf",
    "description": "模型权重文件路径 (.gguf)"
  },

  "gpu": {
    "n_gpu_layers": 99,
    "_n_gpu_layers": "offload 到 GPU 的层数 (0=纯CPU, 99=全部)",
    "flash_attn": true,
    "_flash_attn": "启用 Flash Attention，显著降低显存占用",
    "cache_type_k": "q4_0",
    "_cache_type_k": "KV Cache K 类型: f16 / q8_0 / q4_0。长上下文必须用q4_0省75%显存",
    "cache_type_v": "q4_0",
    "_cache_type_v": "KV Cache V 类型: f16 / q8_0 / q4_0"
  },

  "context": {
    "ctx_size": 262144,
    "_ctx_size": "上下文长度 (tokens)。256K超长上下文，需q4_0 KV Cache节省显存",
    "parallel": 1,
    "_parallel": "并发请求槽数=1，单个对话独享256K完整上下文",
    "cont_batching": true,
    "_cont_batching": "连续批处理，提升吞吐量"
  },

  "cpu": {
    "threads": 16,
    "_threads": "CPU 推理线程数。5950X 32核建议 16~24",
    "threads_batch": 16,
    "_threads_batch": "批处理线程数"
  },

  "server": {
    "port": 8080,
    "_port": "API 服务端口",
    "host": "0.0.0.0",
    "_host": "绑定地址 (0.0.0.0=允许局域网, 127.0.0.1=仅本机)",
    "timeout": 300,
    "_timeout": "请求超时时间 (秒)"
  },

  "sampling": {
    "temp": 0.7,
    "_temp": "采样温度 (0.0~2.0)",
    "top_k": 40,
    "_top_k": "Top-K 采样 (1~100)",
    "top_p": 0.95,
    "_top_p": "Top-P (Nucleus) 采样 (0.0~1.0)",
    "min_p": 0.05,
    "_min_p": "Min-P 采样 (0.0~1.0)",
    "repeat_penalty": 1.1,
    "_repeat_penalty": "重复惩罚倍数 (1.0=无惩罚)",
    "presence_penalty": 0.0,
    "_presence_penalty": "存在惩罚 (-2.0~2.0)",
    "frequency_penalty": 0.0,
    "_frequency_penalty": "频率惩罚 (-2.0~2.0)"
  },

  "generation": {
    "n_predict": -1,
    "_n_predict": "单次最大生成 token 数 (-1=无限制)",
    "seed": -1,
    "_seed": "随机种子 (-1=随机)"
  },

  "memory": {
    "mlock": false,
    "_mlock": "mlock 锁定内存 (需管理员权限)",
    "no_mmap": false,
    "_no_mmap": "禁用内存映射"
  },

  "logging": {
    "verbose": false,
    "_verbose": "详细日志输出"
  },

  "advanced": {
    "extra_args": "",
    "_extra_args": "额外自定义参数"
  }
}
